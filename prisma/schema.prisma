generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model Student {
  id            Int      @id @default(autoincrement())
  name          String
  class         String
  subject       String?
  section       String?
  abs           Boolean  @default(false)
  late          Boolean  @default(false)
  materials     String?
  classwork     String?
  homework      String?
  behavior      String?
  participation String?
  remarks       String?
  action        String?
  others        String?
  createdAt     DateTime @default(now())

  
}